---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = (import.meta.env.BASE_URL as string).replace(/\/?$/, '/');
const stories = await getCollection('stories');

// Sort by date descending (stories with no date go last)
const sorted = stories.sort((a, b) => {
  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
});
---

<Layout>
  <header class="site-header">
    <h1 class="site-header__name">Melissa Keizer</h1>
    <p class="site-header__bio">Freelance pet &amp; event photographer based in Bangor, Northern Ireland.</p>
  </header>

  <main>
    <div class="stories-grid" id="stories">
      {sorted.map((story) => {
        const cover = story.data.coverImage || story.data.photos[0];
        return (
          <article class="story-card">
            {cover && (
              <img
                class="story-card__img"
                src={`${base}${cover.replace(/^\//, '')}`}
                alt={story.data.title}
                loading="lazy"
                decoding="async"
              />
            )}
            <div class="story-card__overlay">
              <h2 class="story-card__title">{story.data.title}</h2>
              {story.data.subtitle && <p class="story-card__subtitle">{story.data.subtitle}</p>}
              <div class="story-card__meta">
                {story.data.date && <span>{story.data.date}</span>}
                {story.data.categories.map(cat => (
                  <a href={`${base}categories/${cat.toLowerCase().replace(/\s+/g, '-')}`}>{cat}</a>
                ))}
              </div>
            </div>
            <a class="story-card__link" href={`${base}stories/${story.id}`} aria-label={`View ${story.data.title}`}></a>
          </article>
        );
      })}
    </div>
  </main>
</Layout>
