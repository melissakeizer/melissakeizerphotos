---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Melissa Keizer Photography" description="Get in touch with Melissa Keizer, pet & event photographer based in Bangor, Northern Ireland.">
  <main>
    <div class="contact-page">
      <h1 class="contact-page__title">Get in Touch</h1>
      <p class="contact-page__intro">
        Interested in a pet session or have a question? I'd love to hear from you.
      </p>

      <!-- Replace YOUR_FORM_ID with your Formspree form ID from formspree.io -->
      <form
        class="contact-form"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
      >
        <div>
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required placeholder="Your name" />
        </div>
        <div>
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="your@email.com" />
        </div>
        <div>
          <label for="message">Message</label>
          <textarea id="message" name="message" required placeholder="Tell me about your pet, the occasion, or anything else..."></textarea>
        </div>
        <button type="submit">Send Message</button>
      </form>
    </div>
  </main>
</Layout>
