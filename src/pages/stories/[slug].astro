---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const base = (import.meta.env.BASE_URL as string).replace(/\/?$/, '/');

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.id },
    props: { story },
  }));
}

interface Props {
  story: CollectionEntry<'stories'>;
}

interface Section {
  title: string | null;
  text: string;
  photos: string[];
}

const { story } = Astro.props;
const { data, body } = story;
const cover = data.coverImage || data.photos[0];
const isStory = data.type === 'story';

// Parse sections from markdown body for story type posts
let sections: Section[] = [];
if (isStory && body && body.trim()) {
  try {
    sections = JSON.parse(body.trim());
  } catch {
    sections = [];
  }
}

// For gallery type: all photos excluding cover
const galleryPhotos = data.coverImage ? data.photos : data.photos.slice(1);

function photoUrl(path: string) {
  return `${base}${path.replace(/^\//, '')}`;
}
---

<Layout title={data.title} description={data.description || undefined} image={cover ? photoUrl(cover) : undefined}>
  {cover && (
    <div class="story-hero-wrapper">
      <img
        class="story-hero"
        src={photoUrl(cover)}
        alt={data.title}
      />
    </div>
  )}

  <div class="story-page">
    <header class="story-header">
      <a class="story-header__back" href={base}>← All Stories</a>
      <h1 class="story-header__title">{data.title}</h1>
      {data.subtitle && <p class="story-header__subtitle">{data.subtitle}</p>}
      <div class="story-header__meta">
        {data.date && <span>{data.date}</span>}
        {data.categories.map(cat => (
          <a href={`${base}categories/${cat.toLowerCase().replace(/\s+/g, '-')}`}>{cat}</a>
        ))}
      </div>
      <hr class="story-divider" />
    </header>

    {/* ── GALLERY LAYOUT ──────────────────────────────────────────────── */}
    {!isStory && (
      <>
        {data.description && (
          <div class="story-intro">
            <p>{data.description}</p>
          </div>
        )}

        {galleryPhotos.length > 0 && (
          <div class="masonry-gallery" id="gallery">
            {galleryPhotos.map((photo, i) => (
              <div
                class="masonry-gallery__item"
                data-index={i}
                data-src={photoUrl(photo)}
                role="button"
                tabindex="0"
                aria-label={`View photo ${i + 1}`}
              >
                <img
                  src={photoUrl(photo)}
                  alt={`${data.title} — photo ${i + 1}`}
                  loading={i < 6 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
            ))}
          </div>
        )}
      </>
    )}

    {/* ── STORY LAYOUT ────────────────────────────────────────────────── */}
    {isStory && (
      <>
        {sections.length > 0 ? (
          <article class="story-article">
            {sections.map((section) => (
              <section class="story-section">
                {section.title && (
                  <h2 class="story-section__title">{section.title}</h2>
                )}
                {section.text && (
                  <div class="story-section__text" set:html={section.text} />
                )}
                {section.photos && section.photos.length > 0 && (
                  <div class={`story-section__photos story-section__photos--${section.photos.length > 1 ? 'pair' : 'single'}`}>
                    {section.photos.map((photo, i) => (
                      <div
                        class="story-section__photo-item"
                        data-src={photoUrl(photo)}
                        role="button"
                        tabindex="0"
                        aria-label={`View photo`}
                      >
                        <img
                          src={photoUrl(photo)}
                          alt={section.title || data.title}
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    ))}
                  </div>
                )}
              </section>
            ))}
          </article>
        ) : (
          /* Fallback if sections not extracted */
          <>
            {data.description && (
              <div class="story-intro"><p>{data.description}</p></div>
            )}
            {galleryPhotos.length > 0 && (
              <div class="masonry-gallery" id="gallery">
                {galleryPhotos.map((photo, i) => (
                  <div
                    class="masonry-gallery__item"
                    data-index={i}
                    data-src={photoUrl(photo)}
                    role="button"
                    tabindex="0"
                    aria-label={`View photo ${i + 1}`}
                  >
                    <img
                      src={photoUrl(photo)}
                      alt={`${data.title} — photo ${i + 1}`}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
            )}
          </>
        )}
      </>
    )}

    {data.footnotes && (
      <aside class="story-footnotes">
        <hr class="story-divider" />
        <h4 class="story-footnotes__title">Footnotes</h4>
        <p>{data.footnotes}</p>
      </aside>
    )}
  </div>

  <!-- Lightbox (shared by both layouts) -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
    <button class="lightbox__prev" id="lightbox-prev" aria-label="Previous photo">&#8249;</button>
    <img class="lightbox__img" id="lightbox-img" src="" alt="" />
    <button class="lightbox__next" id="lightbox-next" aria-label="Next photo">&#8250;</button>
  </div>
</Layout>

<script>
  // Collect all clickable photo items regardless of layout
  const allItems = Array.from(
    document.querySelectorAll<HTMLElement>('.masonry-gallery__item, .story-section__photo-item')
  );

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  if (!lightbox || !lightboxImg || allItems.length === 0) {
    // nothing to wire up
  } else {
    let current = 0;

    function openAt(index: number) {
      current = index;
      const src = allItems[current].dataset.src || '';
      lightboxImg.src = src;
      lightboxImg.alt = allItems[current].querySelector('img')?.alt || '';
      lightbox!.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lightbox!.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    function prev() { openAt((current - 1 + allItems.length) % allItems.length); }
    function next() { openAt((current + 1) % allItems.length); }

    allItems.forEach((item, i) => {
      item.addEventListener('click', () => openAt(i));
      item.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') openAt(i); });
    });

    closeBtn?.addEventListener('click', close);
    prevBtn?.addEventListener('click', prev);
    nextBtn?.addEventListener('click', next);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') prev();
      if (e.key === 'ArrowRight') next();
    });
  }
</script>
